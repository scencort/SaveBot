BOT_TOKEN=123456:ABC-DEF_your_token_from_BotFather

# Раскомментируй, если Telegram блокируется у провайдера и ты ходишь через VPN-клиент
# (Hiddify, WARP, Clash и т.п.). Адрес и порт смотри в настройках своего клиента.
# PROXY=http://127.0.0.1:12334

# --- Способ 1: cookies.txt файл (стабильнее, не зависит от того, открыт ли браузер) ---
# Экспортируй куки из браузера расширением "Get cookies.txt LOCALLY" (Chrome/Edge/Vivaldi/Brave)
# или "cookies.txt" (Firefox), сохрани в проект и укажи путь.
# COOKIES_FILE=cookies.txt

# --- Способ 2: брать куки прямо из браузера ---
# Работает, но на Windows часто требует, чтобы браузер был полностью закрыт.
# Допустимые значения: chrome, edge, firefox, brave, opera, chromium, vivaldi, safari.
# COOKIES_BROWSER=chrome

